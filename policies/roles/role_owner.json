{
  "policy_id": "role:owner",
  "version": "1.0.0",
  "extends": "secureopenclaw",
  "description": "Owner role - all tools, transact requires attestation",

  "resources": ["**"],

  "denied_resources": [],

  "attestations": [
    "action-mode::{tool.id IN ('write', 'edit', 'apply_patch', 'exec', 'process', 'message', 'browser', 'canvas', 'image', 'tts', 'sessions_send', 'sessions_spawn', 'subagents')}",
    "transact-mode::{tool.id IN ('cron', 'gateway', 'nodes')}"
  ],

  "constraints": {
    "rate_limit": 100,
    "parameters": {
      "llm:**": {
        "max_tokens": {"max": 4000}
      }
    },
    "attestations": {
      "action-mode": {
        "approval_criteria": "role:owner",
        "timeout": 0,
        "time_to_live": 14400,
        "one_time": false
      },
      "transact-mode": {
        "approval_criteria": "role:owner",
        "timeout": 300,
        "time_to_live": 3600,
        "one_time": true
      }
    }
  }
}
