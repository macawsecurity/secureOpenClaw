{
  "policy_id": "role:user",
  "version": "1.0.0",
  "extends": "secureopenclaw",
  "description": "User role - observe + act with attestation, no transact",

  "resources": ["tool:**"],

  "denied_resources": [
    "tool:cron",
    "tool:gateway",
    "tool:nodes",
    "file:/etc/**",
    "file:/root/**"
  ],

  "attestations": ["action-mode"],

  "constraints": {
    "rate_limit": 50,
    "parameters": {
      "llm:**": {
        "max_tokens": {"max": 2000}
      }
    },
    "attestations": {
      "action-mode": {
        "approval_criteria": "role:user",
        "timeout": 300,
        "time_to_live": 14400,
        "one_time": false
      }
    }
  }
}
