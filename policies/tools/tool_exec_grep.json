{
  "policy_id": "tool:exec:grep",
  "version": "1.0.0",
  "extends": "tool:exec",
  "description": "SafeBin grep - pattern search with pre-approved grant",

  "resources": ["tool:exec:grep"],

  "attestations": ["grep-grant"],

  "constraints": {
    "parameters": {
      "tool:exec:grep": {
        "pattern": {"type": "string", "required": true, "max_length": 1000},
        "input": {"type": "string", "max_length": 100000},
        "flags": {"type": "string", "allowed_values": ["-i", "-v", "-c", "-n", "-l", "-E", "-F", "-w"]}
      }
    },
    "attestations": {
      "grep-grant": {
        "approval_criteria": "role:admin",
        "time_to_live": 86400,
        "one_time": false
      }
    }
  }
}
