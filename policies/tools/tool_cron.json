{
  "policy_id": "tool:cron",
  "version": "1.0.0",
  "extends": "secureopenclaw",
  "description": "Cron/scheduling - transact level, requires transact-mode",

  "resources": ["tool:cron"],

  "attestations": ["transact-mode"],

  "constraints": {
    "parameters": {
      "tool:cron": {
        "action": {"type": "string", "required": true, "allowed_values": ["list", "create", "delete", "enable", "disable"]},
        "schedule": {"type": "string", "max_length": 100},
        "command": {"type": "string", "max_length": 1000}
      }
    },
    "denied_parameters": {
      "tool:cron": {
        "command": [
          "*rm -rf*",
          "*sudo *",
          "*su -*",
          "*curl * | bash*",
          "*wget * | bash*",
          "*curl * | sh*",
          "*wget * | sh*",
          "*$(*",
          "*`*`*",
          "*${*}*",
          "*eval *",
          "*| python*",
          "*| perl*",
          "*| sh*",
          "*| bash*",
          "*nc -l*",
          "*/dev/tcp/*",
          "*base64*|*"
        ]
      }
    },
    "attestations": {
      "transact-mode": {
        "approval_criteria": "role:owner",
        "timeout": 300,
        "time_to_live": 3600,
        "one_time": true
      }
    }
  }
}
