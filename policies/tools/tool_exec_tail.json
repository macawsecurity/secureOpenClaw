{
  "policy_id": "tool:exec:tail",
  "version": "1.0.0",
  "extends": "tool:exec",
  "description": "SafeBin tail - last N lines with pre-approved grant",

  "resources": ["tool:exec:tail"],

  "attestations": ["tail-grant"],

  "constraints": {
    "parameters": {
      "tool:exec:tail": {
        "input": {"type": "string", "required": true, "max_length": 100000},
        "lines": {"type": "integer", "min": 1, "max": 10000}
      }
    },
    "attestations": {
      "tail-grant": {
        "approval_criteria": "role:admin",
        "time_to_live": 86400,
        "one_time": false
      }
    }
  }
}
