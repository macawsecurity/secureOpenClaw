{
  "policy_id": "tool:tts",
  "version": "1.0.0",
  "extends": "secureopenclaw",
  "description": "Text-to-speech - act level, requires action-mode",

  "resources": ["tool:tts"],

  "attestations": ["action-mode"],

  "constraints": {
    "parameters": {
      "tool:tts": {
        "text": {"type": "string", "required": true, "max_length": 5000}
      }
    },
    "attestations": {
      "action-mode": {
        "approval_criteria": "role:user",
        "timeout": 300,
        "time_to_live": 14400,
        "one_time": false
      }
    }
  }
}
