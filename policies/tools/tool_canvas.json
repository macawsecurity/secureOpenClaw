{
  "policy_id": "tool:canvas",
  "version": "1.0.0",
  "extends": "secureopenclaw",
  "description": "Visual output - act level, requires action-mode",

  "resources": ["tool:canvas"],

  "attestations": ["action-mode"],

  "constraints": {
    "attestations": {
      "action-mode": {
        "approval_criteria": "role:user",
        "timeout": 300,
        "time_to_live": 14400,
        "one_time": false
      }
    }
  }
}
