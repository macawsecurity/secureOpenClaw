{
  "policy_id": "tool:exec:cut",
  "version": "1.0.0",
  "extends": "tool:exec",
  "description": "SafeBin cut - field extraction with pre-approved grant",

  "resources": ["tool:exec:cut"],

  "attestations": ["cut-grant"],

  "constraints": {
    "parameters": {
      "tool:exec:cut": {
        "delimiter": {"type": "string", "max_length": 10},
        "fields": {"type": "string", "required": true, "max_length": 100},
        "input": {"type": "string", "max_length": 100000}
      }
    },
    "attestations": {
      "cut-grant": {
        "approval_criteria": "role:admin",
        "time_to_live": 86400,
        "one_time": false
      }
    }
  }
}
