{
  "policy_id": "skill:admin-recurring",
  "version": "1.0.0",
  "extends": "secureopenclaw",
  "description": "Skill requires admin approval with time bounds",

  "resources": ["skill:**"],

  "attestations": ["skill-admin-recurring"],

  "constraints": {
    "denied_parameters": {
      "tool:*": {
        "path": ["*/etc/*", "*/.ssh/*", "*/.aws/*"]
      }
    },
    "attestations": {
      "skill-admin-recurring": {
        "approval_criteria": "role:admin",
        "timeout": 300,
        "time_to_live": 86400,
        "one_time": false
      }
    }
  }
}
