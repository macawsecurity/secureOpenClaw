{
  "policy_id": "skill:session-grant",
  "version": "1.0.0",
  "extends": "secureopenclaw",
  "description": "Skill requires one-time user approval per session",

  "resources": ["skill:**"],

  "attestations": ["skill-session-approval"],

  "constraints": {
    "denied_parameters": {
      "tool:*": {
        "path": ["*/etc/*", "*/.ssh/*", "*/.aws/*"]
      }
    },
    "attestations": {
      "skill-session-approval": {
        "approval_criteria": "role:user",
        "timeout": 120,
        "time_to_live": 14400,
        "one_time": false
      }
    }
  }
}
